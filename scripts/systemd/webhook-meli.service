# Instalación (una vez):
#   sudo cp scripts/systemd/webhook-meli.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now webhook-meli
#
# Antes del primer arranque, liberar 8080 si hay un webhook viejo:
#   pgrep -af webhook_meli
#   kill <PID>   # o: sudo fuser -k 8080/tcp

[Unit]
Description=Webhook MercadoLibre Service (Flask :8080)
After=network.target
# Evita miles de reinicios si el 8080 sigue ocupado (p. ej. otro webhook_meli.py)
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
User=mckg
Group=mckg
WorkingDirectory=/home/mckg/mi-agente
EnvironmentFile=-/home/mckg/mi-agente/.env
ExecStart=/home/mckg/mi-agente/venv/bin/python3 -u /home/mckg/mi-agente/webhook_meli.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
