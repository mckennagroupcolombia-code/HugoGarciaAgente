MELI_CREDS_PATH=
# Callback en app MeLi (solo documentación; se configura en developers.mercadolibre.com):
# https://bot.mckennagroup.co/notifications  → debe llegar a webhook_meli.py :8080

# Grupos WhatsApp por área
# Inventario: solo el JID en la misma línea (systemd no quita # comentario inline).
# Bien: GRUPO_INVENTARIO_WA=120363407538342427@g.us
# Mal:  GRUPO_INVENTARIO_WA=120363...@g.us  # comentario  → el # se envía al bridge y falla
GRUPO_INVENTARIO_WA=
GRUPO_CONTABILIDAD_WA=         # alias compatibilidad → apuntar al mismo que FACTURACION_COMPRAS
GRUPO_PREVENTA_WA=             # Preventa_Meli (120363393955474672@g.us) — preguntas publicación + reporte IA
GRUPO_POSTVENTA_WA=            # Postventa_Meli (120363406693905719@g.us) — mensajes post-compra MeLi
GRUPO_FACTURACION_VENTAS_WA=   # Facturacion_Ventas_SIIGO — facturas electrónicas de venta
GRUPO_FACTURACION_COMPRAS_WA=  # Facturacion_compras_SIIGO — facturas de compra + alertas de pago
GRUPO_GUIAS_ENVIOS_WA=         # Guias_Envios — guías de despacho Interrapidísimo
# Único grupo pedidos web (Guias_Envios pagina web): alertas + facturar + envio
GRUPO_PEDIDOS_WEB_WA=120363391665421264@g.us
# Solo si hiciera falta más de un JID: GRUPOS_WEB_PEDIDO_CMD_WA=jid1@g.us,jid2@g.us
# Backup nocturno (Drive + aviso WA) y auditoría de scripts (cron); default en código si se omite
GRUPO_ALERTAS_SISTEMAS_WA=120363425113254825@g.us

# Correo transaccional (pedidos web: confirmación y «en camino»)
# Gmail: SMTP_HOST=smtp.gmail.com, puerto 587, app password en SMTP_PASSWORD.
# Si SMTP_USER / SMTP_PASSWORD están vacíos, se usan EMAIL_SENDER y EMAIL_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=McKenna Group

# URL pública del sitio (enlaces e imagen del isotipo en correos)
SITE_URL=https://mckennagroup.co

# --- Página web (Flask PAGINA_WEB/site/website.py): sesiones, OAuth clientes, admin pedidos ---
# Secreto para firmar cookies de sesión (obligatorio en producción; cadena larga aleatoria)
# FLASK_SECRET_KEY=
# Cookies solo por HTTPS (producción detrás de TLS)
# WEB_SESSION_SECURE=1
# Google OAuth — tipo «Aplicación web». Redirect URI debe coincidir exactamente:
#   https://mckennagroup.co/auth/google/callback   (o GOOGLE_OAUTH_REDIRECT_URI explícita)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=
# Panel /admin/pedidos: token dedicado (recomendado). Si vacío, se usa ADMIN_TOKEN del agente.
# Si solo usas correo(s) Google, puedes dejar WEB_ADMIN_TOKEN vacío y definir WEB_ORDER_ADMIN_EMAILS.
# WEB_ADMIN_TOKEN=
# Correo(s) Google (OAuth verificado) con acceso al panel /admin/pedidos — varios separados por coma.
# WEB_ORDER_ADMIN_EMAILS=operaciones@mckennagroup.co
# Listado admin: máximo filas (50–2000). Por defecto 500.
# WEB_ADMIN_ORDERS_LIMIT=500

# Página web: códigos SKU combo en SIIGO (coma) si el listado por type=Combo no los devuelve
# WEB_SIIGO_COMBO_CODES=CB-MI-COMBO-01

# --- API del agente (Flask :8081): /chat, /api/*, panel React en /app ---
# Token Bearer compartido: mismo valor en el panel (login) y en curl -H "Authorization: Bearer ..."
# Genera una cadena larga aleatoria (ej. openssl rand -hex 32). No commitear el .env real.
# Una sola línea CHAT_API_TOKEN=valor (sin espacios alrededor del =). Si systemd carga este .env,
# la PRIMERA aparición del nombre gana: no dejes una línea vacía CHAT_API_TOKEN= arriba del valor real.
CHAT_API_TOKEN=
# Chat widget tienda (PAGINA_WEB) → POST del agente; misma máquina = default 127.0.0.1
# AGENTE_CHAT_URL=http://127.0.0.1:8081/chat
# Token admin (otros usos; el panel usa solo CHAT_API_TOKEN)
ADMIN_TOKEN=

# --- Agente: observabilidad y herramientas de archivos ---
# Logs JSON (una línea) a stderr además del logger: eventos http, tools, preventa
# AGENTE_LOG_JSON=1
# En producción: limita parchear_funcion / crear_nuevo_script / ejecutar_script_python a prefijos del repo
# AGENTE_RESTRICT_FILE_TOOLS=1
# Prefijos relativos a la raíz del repo (coma). Por defecto: scripts/,app/tools/,tests/
# AGENTE_FILE_TOOL_PREFIXES=scripts/,app/tools/,tests/
# Cabecera opcional en clientes HTTP para correlacionar logs (si no se envía, se genera UUID)
# curl -H "X-Request-ID: mi-traza" http://localhost:8081/status

# Auditoría diaria de scripts (cron): scripts/auditar_scripts_cron.py — destino = GRUPO_AUDITORIA_SCRIPTS_WA o GRUPO_ALERTAS_SISTEMAS_WA
# GRUPO_AUDITORIA_SCRIPTS_WA=
# AGENTE_AUDITORIA_SKIP_WA=1   # pruebas: fallos sin WhatsApp
# AGENTE_AUDITORIA_CRON_QUIET=1  # cron: no imprimir línea si todo OK
# Tras backup 2 AM: git add/commit/push si hay cambios (requiere credenciales git en el servidor)
# AGENTE_NIGHTLY_GIT_PUSH=1

# --- Agente de conocimiento (knowledge_agent.py): por defecto Gemini 2.5-Pro (GOOGLE_API_KEY); Ollama es opt-in ---
# AGENTE_SYNTHESIS_PRIMARY=gemini   # default; usar ollama solo si quieres síntesis local en :11434
# AGENTE_SYNTHESIS_FALLBACK_OLLAMA=1   # si primario gemini falla, intentar Ollama (sin esto = nunca llama a Ollama)
# AGENTE_OLLAMA_URL=http://127.0.0.1:11434
# AGENTE_OLLAMA_MODEL=gemma4:latest

# --- Panel 5S (/app → 5S): asistente Hugo vía Ollama local (default hugo-garcia:latest), fallback Gemini si AGENTE_5S_LLM=auto ---
# AGENTE_5S_LLM=auto          # auto | ollama | gemini
# AGENTE_5S_OLLAMA_MODEL=hugo-garcia:latest
# AGENTE_5S_OLLAMA_URL=       # vacío = mismo AGENTE_OLLAMA_URL o http://127.0.0.1:11434

# --- Autocorrección local Hugo (Gemma + bridge) ---
# LOCAL_AI_MODEL=gemma4:26b   # también lo lee scripts/bootstrap_openhands_local.sh desde .env
# OLLAMA_HOST=http://127.0.0.1:11434   # mismo script (sin /v1)
# OLLAMA_BIN=ollama
# Bridge: {payload} se sustituye por JSON escapado (shlex); no pongas comillas extra alrededor.
# OPENHANDS_CMD=python3 /home/mckg/mi-agente/scripts/openhands_bridge.py --payload {payload}
# Remediación integrada (restart systemd lista blanca) si OPENHANDS_EXEC vacío o placeholder:
# OPENHANDS_BUILTIN=1
# OPENHANDS_EXEC=  # opcional: comando shell OpenHands real que imprima JSON en stdout
#
# --- OpenHands CLI local (Ollama) — aparte del agente Flask ---
# 1) uv tool install openhands --python 3.12
# 2) Una vez: bash scripts/bootstrap_openhands_local.sh
#    (toma LOCAL_AI_MODEL / OLLAMA_HOST del entorno o de .env; si no hay nada, default gemma4:26b;
#    OLLAMA_HOST sin sufijo /v1; tool-calling por prompt — evita JSON crudo en la TUI)
#    Ventana <16k: ALLOW_SHORT_CONTEXT_WINDOWS=true por defecto en scripts (Ollama/8k).
#    Razonamiento: bootstrap pone reasoning_effort=null en JSON para evitar error Ollama "does not support thinking".
#    Ruido de herramientas: OPENHANDS_MINIMAL_TOOLS=true deja solo terminal + file_editor (sin task_tracker/delegate).
#    Para exigir 16k: ALLOW_SHORT_CONTEXT_WINDOWS=false bash scripts/bootstrap_openhands_local.sh
#    Si tu stack soporta tool_calls nativos en Ollama: OPENHANDS_OLLAMA_NATIVE_FC=1 bash ...
# 3) Uso: bash scripts/openhands_local.sh
#    o: bash scripts/mckenna_openhands.sh
# Instalación uv: https://astral.sh/uv/install.sh — OpenHands: https://docs.openhands.dev/openhands/usage/cli/installation
